# Copy to .env and fill in. The core graph also runs fully offline via `hydra --demo`.

# --- LLM provider (plan §8 decision #2 — provider is swappable) ---
HYDRA_LLM_PROVIDER=openai
HYDRA_LLM_MODEL=gpt-4o
OPENAI_API_KEY=

# Sampling
HYDRA_TEMPERATURE=0.0

# --- Phase 1: Query Intelligence Layer feature flags ---
HYDRA_ENABLE_MULTI_QUERY=true
HYDRA_ENABLE_DECOMPOSITION=true
HYDRA_ENABLE_HYDE=true
HYDRA_MULTI_QUERY_COUNT=3

# Below this classifier confidence, a "direct" query is escalated to the
# thorough (complex) path. Safer default: never under-serve an ambiguous query.
HYDRA_INTENT_CONFIDENCE_FLOOR=0.5
