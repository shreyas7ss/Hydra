# Copy to .env and fill in. The core graph also runs fully offline via `hydra --demo`.

# --- LLM provider (plan §8 decision #2 — provider is swappable) ---
# Supported providers: openai, gemini
HYDRA_LLM_PROVIDER=gemini
# Model default is provider-aware (gpt-4o for openai, gemini-2.5-flash for gemini);
# override here if you want a specific model.
# HYDRA_LLM_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
GOOGLE_API_KEY=

# To run retrieval fully on Gemini too, set:
# HYDRA_EMBEDDING_PROVIDER=gemini   # uses text-embedding-004

# Sampling
HYDRA_TEMPERATURE=0.0

# --- Phase 1: Query Intelligence Layer feature flags ---
HYDRA_ENABLE_MULTI_QUERY=true
HYDRA_ENABLE_DECOMPOSITION=true
HYDRA_ENABLE_HYDE=true
HYDRA_MULTI_QUERY_COUNT=3

# Below this classifier confidence, a "direct" query is escalated to the
# thorough (complex) path. Safer default: never under-serve an ambiguous query.
HYDRA_INTENT_CONFIDENCE_FLOOR=0.5

# --- Phase 4: Corrective RAG (CRAG) + Self-RAG ---
HYDRA_CRAG_MAX_RETRIES=2         # secondary-retrieval attempts before giving up (ask_user)
HYDRA_REFLECT_MAX_RETRIES=1      # regenerations allowed on an unfaithful answer
HYDRA_GENERATION_CONTEXT_K=5     # top candidates passed to the generator

# --- Phase 3: PageIndex tree search ---
HYDRA_ENABLE_PAGEINDEX=true
HYDRA_PAGEINDEX_BEAM_WIDTH=2     # tree-search beam (1 = greedy single path)
HYDRA_PAGEINDEX_FOLLOW_REFS=true # follow "see Note X" cross-references
HYDRA_PAGEINDEX_DOC_VOTE_K=5     # top-k chunks vote for the target document

# --- Numeric accuracy ---
HYDRA_ENABLE_POT=true            # program-of-thought: execute LLM-emitted arithmetic
